# Copy this file to .env and fill in your values

# Required: Google Gemini API key
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Model to use — set to whichever model your API key has access to.
# Known working options (check https://aistudio.google.com for latest names):
#   gemini-2.0-flash                   ← stable, recommended default
#   gemini-2.5-flash-preview-05-20     ← latest preview (use exact date suffix)
#   gemini-1.5-flash                   ← older stable
GEMINI_MODEL=gemini-2.0-flash
